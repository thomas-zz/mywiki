{
  "name": "mywiki-cli",
  "version": "0.3.1",
  "description": "个人知识 wiki — AI 驱动的结构化理解网络",
  "type": "module",
  "bin": {
    "mywiki": "./bin/mywiki.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "skill/",
    "templates/",
    "site-dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "cd site && npm run lint",
    "test": "node --test",
    "build": "npm run build:skill && npm run build:site",
    "build:skill": "rm -rf skill && cp -r docs/mywiki skill",
    "build:site": "bash scripts/build-site.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wiki",
    "knowledge",
    "ai",
    "claude",
    "skill",
    "personal-knowledge"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.0.0"
  }
}
